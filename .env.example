# =========================================================================
# CONFIGURATION TEMPLATE (PLEASE READ)
# =========================================================================
# This file is a TEMPLATE for your local configuration. 
# It shows what settings the application needs to run correctly.
#
# HOW TO USE THIS FILE:
# 1. Create a copy of this file in the same folder.
# 2. Rename the new copy to exactly ".env" (remove ".example" from the name).
# 3. Open the new ".env" file and replace the placeholders below 
#    (like USER, PASSWORD, HOST) with your actual database details.
#
# IMPORTANT: Never share your real ".env" file or upload it to GitHub. 
# It contains sensitive passwords that must be kept secret.
# =========================================================================

# Application Server Configuration
# PORT: The port number where this Express server will run on your computer.
# Standard web applications often use 3000, 5000, or 8080.
PORT=6000

# Database Configuration
# Replace USER, PASSWORD, HOST, PORT, and DATABASE with your PostgreSQL connection details.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT Configuration
# Change this text to a long, random string of symbols to secure user logins.
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
