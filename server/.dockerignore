# Git and Docker Metadata
.git
.gitignore
.dockerignore
.gitattributes
LICENSE
README.md

# Local Dependencies
node_modules/
.npm/
.yarn/
.pnpm-store/

# Build Outputs and Caches
dist/
build/
out/
.cache/
*.tsbuildinfo

# Environment variables & secrets
.env
.env.*
secret.json
config.json
*.pem
*.key
**/.env
**/secrets.dev.yaml
**/values.dev.yaml

# Logs and System Files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db

# IDE configurations & local metadata
.idea/
.vscode/
*.code-workspace

# Local API Testing and Tools
.postman/
postman/
.bruno/
.http-client/
http-tests/
*.http

# Docker Orchestration (Optional to ignore)
# Dockerfile*
# docker-compose*
# compose.y*ml