@baseUrl = http://localhost:7000
@authToken = insert_your_token_here

### Get all movies
GET {{baseUrl}}/movies

### Get movie by ID
GET {{baseUrl}}/movies/1

### Create movie: Interstellar
POST {{baseUrl}}/movies
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "movieName": "Interstellar",
    "description": "When Earth becomes uninhabitable, a team of explorers travels through a wormhole in space in an attempt to ensure humanity's survival on a new planet.",
    "duration": 169,
    "ageLimit": false
}

### Create movie: Dune: Part Two
POST {{baseUrl}}/movies
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "movieName": "Dune: Part Two",
    "description": "Paul Atreides unites with Chani and the Fremen while seeking revenge against the conspirators who destroyed his family. Facing a choice between the love of his life and the fate of the universe, he endeavors to prevent a terrible future.",
    "duration": 166,
    "ageLimit": false
}

### Create movie: Oppenheimer
POST {{baseUrl}}/movies
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "movieName": "Oppenheimer",
    "description": "The story of American scientist J. Robert Oppenheimer and his role in the development of the atomic bomb, which changed the course of history forever.",
    "duration": 180,
    "ageLimit": true
}

### Create movie: The Conjuring
POST {{baseUrl}}/movies
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "movieName": "The Conjuring",
    "description": "Paranormal investigators Ed and Lorraine Warren work to help a family terrorized by a dark presence in their secluded farmhouse, facing the most terrifying case of their lives.",
    "duration": 112,
    "ageLimit": true
}

### Update movie
PATCH {{baseUrl}}/movies/1
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "ageLimit": true
}

### Delete movie
DELETE {{baseUrl}}/movies/1
Authorization: Bearer {{authToken}}